{
  "name": "amazing-scraper",
  "version": "1.1.3",
  "description": "TypeScript library for scraping Amazon Brasil coupon product listings",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/",
    "example-coupon": "tsx examples/extract-coupon.ts",
    "example-product": "tsx examples/fetch-product.ts"
  },
  "keywords": [
    "amazon",
    "scraper",
    "coupon",
    "brazil"
  ],
  "author": "Emanuel Ozorio Dias",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/itsmaneka/amazing-scraper.git"
  },
  "bugs": {
    "url": "https://github.com/itsmaneka/amazing-scraper/issues"
  },
  "homepage": "https://github.com/itsmaneka/amazing-scraper#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "axios-cookiejar-support": "^6.0.5",
    "cheerio": "^1.0.0",
    "tough-cookie": "^4.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/tough-cookie": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nock": "^14.0.11",
    "ts-jest": "^29.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  }
}
