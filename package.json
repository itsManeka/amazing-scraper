{
  "name": "amazing-scraper",
  "version": "1.16.0",
  "description": "TypeScript library for scraping Amazon Brasil coupon product listings",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --ci --watchAll=false --maxWorkers=1",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "release": "semantic-release",
    "docs": "typedoc",
    "example-coupon": "tsx examples/extract-coupon.ts",
    "example-product": "tsx examples/fetch-product.ts",
    "example-pre-sales": "tsx examples/fetch-pre-sales.ts"
  },
  "keywords": [
    "amazon",
    "scraper",
    "coupon",
    "brazil"
  ],
  "author": "Emanuel Ozorio Dias",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/itsmaneka/amazing-scraper.git"
  },
  "bugs": {
    "url": "https://github.com/itsmaneka/amazing-scraper/issues"
  },
  "homepage": "https://github.com/itsmaneka/amazing-scraper#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix"
    ],
    "tests/**/*.ts": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "axios": "^1.15.0",
    "axios-cookiejar-support": "^6.0.5",
    "cheerio": "^1.0.0",
    "tough-cookie": "^4.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/tough-cookie": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.3.2",
    "nock": "^14.0.11",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.1.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.2"
  }
}
